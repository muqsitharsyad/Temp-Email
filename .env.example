# Salin ke .env lalu sesuaikan

# Pilih backend:
#   mailtm = pakai layanan publik api.mail.tm (TIDAK butuh domain / port 25).
#   smtp   = self-host SMTP server sendiri (BUTUH domain dengan MX record).
MAIL_PROVIDER=mailtm

# Hanya dipakai jika MAIL_PROVIDER=smtp
MAIL_DOMAINS=mail.example.com
MAIL_TTL_MINUTES=60
MAX_PER_INBOX=50
SMTP_PORT=25

HTTP_PORT=9002

# Sub-path saat di belakang reverse proxy. Kosongkan jika di root domain.
BASE_PATH=/dockdock/temp-email
